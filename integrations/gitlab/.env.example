# GitLab poller configuration. Copy to .env and edit:
#   cp .env.example .env
# .env is auto-loaded by poller.py if present in the cwd. .env is gitignored;
# .env.example is checked in as a template.

# Required — base URL of your GitLab instance (no trailing slash).
GITLAB_URL=https://gitlab.example.com

# Required — personal access token with read_api scope.
GITLAB_TOKEN=replace-me

# Required — comma-separated project paths (URL-encoded slash is fine, but
# the poller accepts the human-readable form too).
PROJECTS=myteam/backend,myteam/frontend
